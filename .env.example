# Puerto del portal web
FRONTEND_PORT=80

# Proxy /api/* hacia el backend (recomendado en local para cookies same-origin)
API_PROXY_ENABLED=true
API_UPSTREAM=http://host.docker.internal:8000

# Base URL que usa el navegador para llamar a la API.
# Con proxy nginx o ALB same-origin: /api/v1
# Sin proxy (CORS en el API): http://localhost:8000/api/v1
API_BASE_URL=/api/v1

# --- Producción AWS: un ALB compartido (HTTP por ahora) ---
#
# El navegador usa el DNS del ALB. Reglas del listener:
#   /api/*      -> target group API (puerto 8000)
#   /webhook/*  -> target group API (puerto 8000)
#   default     -> target group frontend (puerto 80)
#
API_PROXY_ENABLED=false
API_BASE_URL=/api/v1
#
# Portal: http://coyote-application-alb-530949404.us-east-2.elb.amazonaws.com/
# Cuando habiliten HTTPS en el ALB, no cambia nada aquí (sigue siendo /api/v1 relativo).
# Health check ALB (target group frontend): GET /health -> 200
